# ModelMux Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# FREE TIER PROVIDERS (Recommended for development)
# =============================================================================

# Kilo.ai Gateway - Access to 500+ models with free tier
# Get API key: https://kilo.ai
KILO_API_KEY=your_kilo_api_key_here
KILO_BASE_URL=https://api.kilo.ai/api/gateway

# Moonshot (Kimi) - Chinese LLM provider with free tier
# Get API key: https://platform.moonshot.cn
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek - Code and chat models with free tier
# Get API key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# PAID PROVIDERS
# =============================================================================

# OpenAI - GPT-4, GPT-4o, GPT-4o-mini
# Get API key: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic - Claude Sonnet, Opus, Haiku
# Get API key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google - Gemini models
# Get API key: https://makersuite.google.com
GOOGLE_GEMINI_API_KEY=your_google_api_key_here
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# =============================================================================
# LOCAL PROVIDERS (No API key required)
# =============================================================================

# Ollama - Local LLM runner
# Install: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# LMStudio - Local LLM server with OpenAI-compatible API
# Install: https://lmstudio.ai
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# =============================================================================
# SEARCH APIs (Optional - for RAG and web search)
# =============================================================================

# Brave Search API
# Get API key: https://brave.com/search/api
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Tavily Search API (AI-optimized search)
# Get API key: https://tavily.com
TAVILY_SEARCH_API_KEY=your_tavily_api_key_here

# =============================================================================
# MODELmux CONFIGURATION (Optional)
# =============================================================================

# Default model to use when none specified
# Format: provider/model-name (e.g., kilo_code/minimax-minimax-m2.5:free)
MODELMUX_DEFAULT_MODEL=kilo_code/deepseek/deepseek-chat

# Fallback model when primary is unavailable
# MODELmux_FALLBACK_MODEL=moonshot/moonshot-v1-8k

# Request timeout in seconds (default: 120)
# MODELmux_TIMEOUT=120

# Enable streaming responses (default: true)
# MODELmux_STREAMING=true

# Enable response caching (default: true)
# MODELmux_CACHE=true
MODELMUX_CLAUDE_DEFAULT_MODEL=kilo_code/deepseek/deepseek-chat
